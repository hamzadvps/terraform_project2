# Terraform directories
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Terraform lock file
.terraform.lock.hcl

# Variable files (often contain secrets)
*.tfvars
*.tfvars.json

# ZIP archives
*.zip

# Logs
*.log

# Crash logs
crash.log
crash.*.log

# Sensitive files
*.pem
*.key


PUSH THIS
main.tf
variables.tf
outputs.tf
provider.tf
versions.tf
README.md
.gitignore
modules/


NEVER PUSH THIS
.terraform/
terraform.tfstate
terraform.tfstate.backup
*.tfvars
*.pem
*.key
